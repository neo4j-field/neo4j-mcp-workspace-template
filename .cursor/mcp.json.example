{
  "mcpServers": {
    "neo4j-data-modeling": {
      "command": "uvx",
      "args": ["mcp-neo4j-data-modeling@0.8.2", "--transport", "stdio"]
    },
    "neo4j-ingest": {
      "command": "uv",
      "args": ["--directory", "/absolute/path/to/mcp-neo4j-ingest", "run", "mcp-neo4j-ingest"]
    },
    "neo4j-lexical-graph": {
      "command": "uv",
      "args": ["--directory", "/absolute/path/to/mcp-neo4j-lexical-graph", "run", "mcp-neo4j-lexical-graph"]
    },
    "neo4j-entity-graph": {
      "command": "uv",
      "args": ["--directory", "/absolute/path/to/mcp-neo4j-entity-graph", "run", "mcp-neo4j-entity-graph"]
    },
    "neo4j-graphrag": {
      "command": "uv",
      "args": ["--directory", "/absolute/path/to/mcp-neo4j-graphrag", "run", "mcp-neo4j-graphrag"]
    },
    "bigquery": {
      "command": "toolbox",
      "args": ["--prebuilt", "bigquery", "--stdio"],
      "env": {
        "BIGQUERY_PROJECT": "PROJECT_ID"
      }
    }
  }
}
