# ──────────────────────────────────────────────────────────────────────────────
# neo4j-mcp-workspace-template — environment variables
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values, OR run ./setup.sh which
# will prompt you and create .env automatically.
#
# .env is gitignored. Never commit credentials to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Neo4j connection (required) ───────────────────────────────────────────────
# Used by: neo4j-cypher, neo4j-ingest, neo4j-lexical-graph, neo4j-entity-graph
#
# Use neo4j:// for unencrypted local connections (AuraDB uses neo4j+s://)
NEO4J_URI=neo4j://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# ── OpenAI API key (required for lexical-graph and entity-graph) ──────────────
OPENAI_API_KEY=

# ── Embedding model ───────────────────────────────────────────────────────────
# Used by neo4j-lexical-graph to generate vector embeddings for Chunk nodes.
EMBEDDING_MODEL=text-embedding-3-small

# ── Extraction model ──────────────────────────────────────────────────────────
# Used by neo4j-entity-graph for structured entity extraction from text chunks.
EXTRACTION_MODEL=gpt-5-mini

# ── BigQuery (optional) ───────────────────────────────────────────────────────
# Only needed if using the BigQuery MCP server (requires `toolbox` CLI installed)
# See: https://github.com/googleapis/genai-toolbox
# BIGQUERY_PROJECT=your-gcp-project-id
